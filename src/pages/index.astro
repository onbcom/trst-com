---
import BaseLayout from '../components/BaseLayout.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="TRST.com | The Digital Trust Infrastructure Authority"
  description="Exploring the systems that make trust possible: identity verification, reputation networks, and AI trust layers for the 2026 digital economy."
>

<!-- Background particle layer -->
<div class="z-10 mix-blend-screen w-full h-screen absolute top-0">
  <div id="particles-js" class="absolute inset-0 -z-10"></div>
</div>

<div class="relative h-screen overflow-hidden">
  <!-- Decorative grid lines -->
  <div class="pointer-events-none absolute inset-0 z-0">
    <div class="absolute inset-y-0 left-[12.5%] w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
    <div class="absolute inset-y-0 left-[25%] w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
    <div class="absolute inset-y-0 left-[37.5%] w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
    <div class="absolute inset-y-0 left-[50%] w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
    <div class="absolute inset-y-0 left-[62.5%] w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
    <div class="absolute inset-y-0 left-[75%] w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
    <div class="absolute inset-y-0 left-[87.5%] w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
    <div class="absolute inset-x-0 top-[20%] h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>
    <div class="absolute inset-x-0 top-[40%] h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>
    <div class="absolute inset-x-0 top-[60%] h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>
    <div class="absolute inset-x-0 top-[80%] h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>
  </div>

  <!-- Background image -->
  <img
    src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=3840&auto=format&fit=crop"
    alt="Abstract Data Network"
    class="pointer-events-none w-full h-full object-cover absolute top-0 right-0 bottom-0 left-0 opacity-40 mix-blend-overlay"
  />

  <!-- Upper hero visual elements -->
  <div class="pointer-events-none absolute inset-0 z-[6] overflow-hidden">

    <!-- Radial glow behind shield -->
    <div class="absolute top-[38%] left-1/2 -translate-x-1/2 -translate-y-1/2 w-[520px] h-[520px] rounded-full" style="background: radial-gradient(circle, rgba(167,139,250,0.18) 0%, rgba(96,165,250,0.10) 40%, transparent 70%); animation: heroGlow 8s ease-in-out infinite;"></div>

    <!-- Central trust/shield graphic -->
    <div class="absolute top-[38%] left-1/2 -translate-x-1/2 -translate-y-1/2">
      <div style="animation: heroFloat 8s ease-in-out infinite;">
        <svg width="360" height="360" viewBox="0 0 360 360" fill="none" xmlns="http://www.w3.org/2000/svg" style="animation: heroPulse 8s ease-in-out infinite;">
          <!-- Outer rings -->
          <circle cx="180" cy="180" r="168" stroke="white" stroke-width="0.5" stroke-dasharray="3 9" stroke-opacity="0.9"/>
          <circle cx="180" cy="180" r="140" stroke="white" stroke-width="0.5" stroke-dasharray="2 7" stroke-opacity="0.7"/>
          <circle cx="180" cy="180" r="112" stroke="white" stroke-width="0.6" stroke-opacity="0.6"/>
          <!-- Shield body -->
          <path d="M180 38 L292 94 L292 196 C292 256 180 322 180 322 C180 322 68 256 68 196 L68 94 Z" stroke="white" stroke-width="1.5" fill="white" fill-opacity="0.06" stroke-opacity="1"/>
          <!-- Inner shield -->
          <path d="M180 72 L268 116 L268 192 C268 238 180 294 180 294 C180 294 92 238 92 192 L92 116 Z" stroke="white" stroke-width="0.7" fill="none" stroke-opacity="0.65"/>
          <!-- Checkmark -->
          <path d="M148 178 L168 198 L216 150" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" stroke-opacity="1"/>
          <!-- Data nodes -->
          <circle cx="180" cy="180" r="4" fill="white" fill-opacity="0.7"/>
          <circle cx="106" cy="136" r="2.5" fill="white" fill-opacity="0.6"/>
          <circle cx="254" cy="136" r="2.5" fill="white" fill-opacity="0.6"/>
          <circle cx="88" cy="210" r="2" fill="white" fill-opacity="0.5"/>
          <circle cx="272" cy="210" r="2" fill="white" fill-opacity="0.5"/>
          <circle cx="148" cy="88" r="1.5" fill="white" fill-opacity="0.5"/>
          <circle cx="212" cy="88" r="1.5" fill="white" fill-opacity="0.5"/>
          <!-- Connection lines -->
          <line x1="180" y1="180" x2="106" y2="136" stroke="white" stroke-width="0.4" stroke-opacity="0.4"/>
          <line x1="180" y1="180" x2="254" y2="136" stroke="white" stroke-width="0.4" stroke-opacity="0.4"/>
          <line x1="180" y1="180" x2="88" y2="210" stroke="white" stroke-width="0.4" stroke-opacity="0.35"/>
          <line x1="180" y1="180" x2="272" y2="210" stroke="white" stroke-width="0.4" stroke-opacity="0.35"/>
          <line x1="180" y1="180" x2="148" y2="88" stroke="white" stroke-width="0.4" stroke-opacity="0.35"/>
          <line x1="180" y1="180" x2="212" y2="88" stroke="white" stroke-width="0.4" stroke-opacity="0.35"/>
        </svg>
      </div>
    </div>

    <!-- Floating metric card: Trust Score -->
    <div class="absolute hidden md:flex top-[28%] left-[6%] items-center gap-3 rounded-2xl px-4 py-3" style="background: rgba(255,255,255,0.06); backdrop-filter: blur(16px); box-shadow: 0 0 0 1px rgba(255,255,255,0.12), inset 0 1px 0 rgba(255,255,255,0.08); animation: heroFloat 5s ease-in-out infinite 0.5s;">
      <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0" style="background: rgba(192,132,252,0.2); box-shadow: 0 0 0 1px rgba(192,132,252,0.35);">
        <iconify-icon icon="solar:graph-up-linear" class="text-purple-300 text-base"></iconify-icon>
      </div>
      <div>
        <div class="text-[10px] text-white/50 font-geist uppercase tracking-wider leading-none">Trust Score</div>
        <div class="text-white font-geist font-semibold text-xl leading-tight mt-1">924</div>
      </div>
      <div class="w-1.5 h-1.5 rounded-full ml-1 flex-shrink-0" style="background: #a78bfa; box-shadow: 0 0 10px rgba(167,139,250,1);"></div>
    </div>

    <!-- Floating metric card: Verified Identities -->
    <div class="absolute hidden md:flex top-[18%] right-[6%] items-center gap-3 rounded-2xl px-4 py-3" style="background: rgba(255,255,255,0.06); backdrop-filter: blur(16px); box-shadow: 0 0 0 1px rgba(255,255,255,0.12), inset 0 1px 0 rgba(255,255,255,0.08); animation: heroFloat 7s ease-in-out infinite 1s;">
      <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0" style="background: rgba(52,211,153,0.2); box-shadow: 0 0 0 1px rgba(52,211,153,0.35);">
        <iconify-icon icon="solar:users-group-two-rounded-linear" class="text-emerald-300 text-base"></iconify-icon>
      </div>
      <div>
        <div class="text-[10px] text-white/50 font-geist uppercase tracking-wider leading-none">Verified Identities</div>
        <div class="text-white font-geist font-semibold text-xl leading-tight mt-1">2.4M</div>
      </div>
      <div class="w-1.5 h-1.5 rounded-full ml-1 flex-shrink-0" style="background: #34d399; box-shadow: 0 0 10px rgba(52,211,153,1);"></div>
    </div>

    <!-- Floating metric card: ZK Proofs -->
    <div class="absolute hidden md:flex top-[48%] right-[5%] items-center gap-3 rounded-2xl px-4 py-3" style="background: rgba(255,255,255,0.06); backdrop-filter: blur(16px); box-shadow: 0 0 0 1px rgba(255,255,255,0.12), inset 0 1px 0 rgba(255,255,255,0.08); animation: heroFloat 6s ease-in-out infinite 2s;">
      <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0" style="background: rgba(96,165,250,0.2); box-shadow: 0 0 0 1px rgba(96,165,250,0.35);">
        <iconify-icon icon="solar:shield-keyhole-linear" class="text-blue-300 text-base"></iconify-icon>
      </div>
      <div>
        <div class="text-[10px] text-white/50 font-geist uppercase tracking-wider leading-none">ZK Proofs</div>
        <div class="text-white font-geist font-semibold text-sm leading-tight mt-1">Active</div>
      </div>
      <div class="w-1.5 h-1.5 rounded-full ml-1 flex-shrink-0" style="background: #60a5fa; box-shadow: 0 0 10px rgba(96,165,250,1);"></div>
    </div>

    <!-- Floating metric card: Threat Blocks (new) -->
    <div class="absolute hidden lg:flex top-[12%] left-[9%] items-center gap-3 rounded-2xl px-4 py-3" style="background: rgba(255,255,255,0.06); backdrop-filter: blur(16px); box-shadow: 0 0 0 1px rgba(255,255,255,0.12), inset 0 1px 0 rgba(255,255,255,0.08); animation: heroFloat 9s ease-in-out infinite 3s;">
      <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0" style="background: rgba(251,146,60,0.2); box-shadow: 0 0 0 1px rgba(251,146,60,0.35);">
        <iconify-icon icon="solar:danger-triangle-linear" class="text-orange-300 text-base"></iconify-icon>
      </div>
      <div>
        <div class="text-[10px] text-white/50 font-geist uppercase tracking-wider leading-none">Threat Blocks</div>
        <div class="text-white font-geist font-semibold text-xl leading-tight mt-1">18.7K</div>
      </div>
      <div class="w-1.5 h-1.5 rounded-full ml-1 flex-shrink-0" style="background: #fb923c; box-shadow: 0 0 10px rgba(251,146,60,1);"></div>
    </div>

  </div>

  <!-- Header -->
  <header class="z-10 border-white/5 border-b relative">
    <div class="flex md:px-8 max-w-7xl mx-auto py-5 px-6 items-center justify-between">
      <!-- Left: brand + primary nav -->
      <div class="flex md:gap-6 ring-white/5 ring-1 [animation:fadeSlideIn_1s_ease-out_0.1s_both] rounded-full p-1 gap-4 items-center bg-black/20 backdrop-blur-md">
        <a href="/" class="inline-flex items-center justify-center px-4 h-[36px] rounded-full text-white font-geist font-semibold tracking-tight text-lg">TRST.com</a>
        <nav class="hidden md:flex gap-2 items-center">
          <a href="#map" class="inline-flex items-center gap-2 transition hover:bg-white/10 hover:ring-white/20 text-sm font-medium text-white/90 font-geist bg-white/5 ring-white/10 ring-1 rounded-full py-2 px-3.5 backdrop-blur-sm">
            Infrastructure Map
          </a>
          <a href="#frameworks" class="inline-flex items-center gap-2 transition hover:bg-white/10 hover:ring-white/20 text-sm font-medium text-white/90 font-geist bg-white/5 ring-white/10 ring-1 rounded-full py-2 px-3.5 backdrop-blur-sm">
            Frameworks
          </a>
          <a href="#scorecard" class="inline-flex items-center gap-2 transition hover:bg-white/10 hover:ring-white/20 text-sm font-medium text-white/90 font-geist bg-white/5 ring-white/10 ring-1 rounded-full py-2 px-3.5 backdrop-blur-sm">
            Scorecard
          </a>
          <a href="/about" class="inline-flex items-center gap-2 transition hover:bg-white/10 hover:ring-white/20 text-sm font-medium text-white/90 font-geist bg-white/5 ring-white/10 ring-1 rounded-full py-2 px-3.5 backdrop-blur-sm">
            About
          </a>
        </nav>
      </div>

      <!-- Right: CTA -->
      <div class="flex ring-white/5 ring-1 rounded-full p-1 gap-2 items-center bg-black/20 backdrop-blur-md">
        <a href="#map" class="hidden sm:inline-flex items-center gap-2 transition hover:bg-white/10 hover:ring-white/20 [animation:fadeSlideIn_1s_ease-out_0.2s_both] text-sm font-medium text-white/90 font-geist bg-white/5 ring-white/10 ring-1 rounded-full py-2 px-3.5 backdrop-blur-sm">
          Explore the Trust Map
        </a>
      </div>
    </div>
    <div id="wrapper">
      <div class="gradient-blur">
        <div></div><div></div><div></div><div></div><div></div><div></div>
      </div>
    </div>
  </header>

  <!-- Hero Content -->
  <main class="z-10 flex h-[calc(100vh-80px)] relative items-end">
    <section class="md:px-8 md:pb-16 lg:pb-20 w-full max-w-7xl mx-auto px-6 pb-12">
      <!-- Top divider -->
      <div class="mb-12 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

      <div class="grid grid-cols-1 md:grid-cols-12 md:gap-6 lg:gap-10 gap-8 items-center">
        <!-- Column 1: Tag + Headline -->
        <div class="md:col-span-6 lg:col-span-6 relative">
          <div class="inline-flex text-xs font-medium text-white/80 font-geist bg-white/5 ring-white/10 ring-1 rounded-full mb-5 py-1.5 px-3 backdrop-blur-sm gap-2 items-center [animation:fadeSlideIn_1s_ease-out_0.1s_both]">
            <iconify-icon icon="solar:shield-check-linear" class="text-white/80 text-sm"></iconify-icon>
            Digital Trust Protocol
          </div>
          <h1 class="leading-tight text-4xl sm:text-5xl md:text-5xl lg:text-6xl [animation:fadeSlideIn_1s_ease-out_0.2s_both] tracking-tighter font-geist">
            The Infrastructure
            <span class="block bg-clip-text text-transparent tracking-tighter font-geist bg-gradient-to-r from-white via-white/80 to-white/40">of Confidence</span>
          </h1>
        </div>

        <!-- Vertical divider -->
        <div class="hidden md:block md:col-span-1 lg:col-span-1 relative">
          <div class="absolute left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-white/20 via-white/10 to-white/5 -translate-x-1/2"></div>
        </div>

        <!-- Column 2: Description -->
        <div class="md:col-span-5 lg:col-span-5 [animation:fadeSlideIn_1s_ease-out_0.3s_both] relative">
          <p class="leading-relaxed md:text-lg text-base text-white/70 font-geist">
            As the global economy transitions to AI-driven interactions, trust is the only currency that matters. TRST defines the systems that verify identity, secure transactions, and scale reputation across the digital frontier.
          </p>
          <div class="border-white/10 border-t mt-6 pt-6">
            <div class="flex gap-4 text-sm text-white/50 items-center">
              <div class="flex items-center gap-2">
                <iconify-icon icon="solar:lock-keyhole-linear" class="text-slate-400 text-base"></iconify-icon>
                <span class="font-geist text-slate-300">Enterprise-grade security</span>
              </div>
            </div>
          </div>

          <div class="mt-8 flex flex-row gap-3">
            <a href="#map" class="inline-flex items-center justify-center gap-2 ring-1 ring-white/20 transition hover:bg-neutral-100 whitespace-nowrap [animation:fadeSlideIn_1s_ease-out_0.5s_both] text-sm font-medium text-neutral-900 font-geist bg-white rounded-full py-2.5 px-4">
              Explore the Trust Map
              <iconify-icon icon="solar:arrow-right-linear" class="text-base"></iconify-icon>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Subtle vignette -->
  <div class="pointer-events-none absolute inset-0 shadow-[inset_0_0_100px_rgba(0,0,0,0.8)]"></div>
</div>

<!-- Trust Stack / Infrastructure Map -->
<section class="overflow-hidden lg:py-24 py-16 relative bg-slate-950" id="map">
  <!-- Decorative grid lines -->
  <div class="pointer-events-none z-0 absolute inset-0">
    <div class="absolute inset-y-0 left-[15%] w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
    <div class="absolute inset-y-0 left-[35%] w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
    <div class="absolute inset-y-0 left-1/2 w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
    <div class="absolute inset-y-0 left-[65%] w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
    <div class="absolute inset-y-0 left-[85%] w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
    <div class="absolute inset-x-0 top-[25%] h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>
    <div class="absolute inset-x-0 top-[50%] h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>
    <div class="absolute inset-x-0 top-[75%] h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>
  </div>

  <div class="z-10 md:px-8 flex flex-col h-full max-w-7xl mx-auto px-6 relative">

    <!-- Primary Description -->
    <div class="mb-16 max-w-3xl animate-on-scroll [animation:fadeSlideIn_1s_ease-out_0.1s_both]">
      <div class="inline-flex items-center gap-2 rounded-full bg-white/5 px-3 py-1.5 text-xs font-medium text-white/80 ring-1 ring-white/10 font-geist mb-4">
        <iconify-icon icon="solar:layers-linear" class="text-sm"></iconify-icon>
        The Trust Stack
      </div>
      <h2 class="text-3xl md:text-5xl font-semibold tracking-tight font-geist mb-6 text-white">Digital Utility for 2026</h2>
      <p class="text-white/70 md:text-lg text-base leading-relaxed font-geist">
        Digital trust is no longer a luxury; it is the vital utility of the 2026 internet. TRST.com catalogs the evolving landscape of trust layers—from decentralized identity (DID) and biometric authentication to AI-agent verification and fraud prevention networks.
      </p>
    </div>

    <div class="flex-1 flex items-center">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 w-full">

        <!-- Feature 1: Verification -->
        <div class="overflow-hidden md:p-4 flex flex-col bg-gradient-to-b from-white/10 to-white/5 h-full ring-white/10 ring-1 rounded-3xl p-3 relative backdrop-blur-md animate-on-scroll [animation:fadeSlideIn_1s_ease-out_0.2s_both]">
          <div class="relative rounded-2xl overflow-hidden ring-1 ring-white/10 flex-1 bg-black/50">
            <img src="https://images.unsplash.com/photo-1526304640581-d334cdbbf45e?q=80&w=800&auto=format&fit=crop" alt="Biometric mapping" class="min-h-[220px] md:min-h-[260px] w-full h-full object-cover opacity-60 mix-blend-luminosity" />
            <div class="absolute top-3 md:top-4 left-4 right-4 flex items-center justify-between">
              <span class="text-slate-100 text-sm md:text-base font-medium font-geist tracking-tight">Level 4 Assurance</span>
              <span class="text-[11px] md:text-xs text-slate-300/80 font-geist border border-white/20 rounded-full px-2 py-0.5 bg-black/40 backdrop-blur">DID Protocol</span>
            </div>
            <div class="absolute bottom-3 left-4 right-4 flex items-center gap-2">
              <div class="flex items-center gap-1.5 bg-black/60 backdrop-blur-sm px-2.5 py-1 rounded-full border border-white/10">
                <div class="w-1.5 h-1.5 rounded-full bg-emerald-400"></div>
                <span class="text-[10px] text-slate-200 font-geist uppercase tracking-wider">Verified Identity</span>
              </div>
            </div>
          </div>
          <div class="relative px-2 md:px-1 pt-5 pb-2">
            <div class="flex items-center gap-2 mb-1">
              <iconify-icon icon="solar:fingerprint-circle-linear" class="text-emerald-400 text-lg"></iconify-icon>
              <h3 class="md:text-xl text-lg font-semibold tracking-tight font-geist text-white">1. Verification</h3>
            </div>
            <p class="text-sm text-slate-400 font-geist mt-2">Cryptographic and biometric proofs to establish absolute origin certainty across human and synthetic actors.</p>
          </div>
        </div>

        <!-- Feature 2: Authentication -->
        <div class="rounded-3xl bg-slate-900/60 ring-1 ring-white/10 backdrop-blur-md p-6 flex flex-col h-full animate-on-scroll [animation:fadeSlideIn_1s_ease-out_0.3s_both]">
          <div class="inline-flex items-center gap-2 rounded-full bg-white/5 px-3 py-1.5 text-xs font-medium text-white/80 ring-1 ring-white/10 font-geist w-fit mb-6">
            <iconify-icon icon="solar:shield-keyhole-linear" class="text-sm text-blue-400"></iconify-icon>
            Zero-Trust Access
          </div>
          <div class="flex-1 flex flex-col justify-between">
            <div>
              <div class="md:text-5xl text-4xl font-medium tracking-tighter font-geist text-white">Continuous</div>
              <p class="text-slate-400 text-sm font-geist mt-2">Session authorization status</p>

              <div class="mt-8 space-y-4">
                <div class="flex items-center justify-between text-sm">
                  <span class="text-slate-300 font-geist">Behavioral Modeling</span>
                  <span class="text-blue-300 font-geist font-medium">Active</span>
                </div>
                <div class="w-full bg-white/5 h-1.5 rounded-full overflow-hidden">
                  <div class="bg-blue-400 h-full w-full rounded-full shadow-[0_0_10px_rgba(96,165,250,0.5)]"></div>
                </div>

                <div class="flex items-center justify-between text-sm pt-2">
                  <span class="text-slate-300 font-geist">Contextual Awareness</span>
                  <span class="text-blue-300 font-geist font-medium">99.9%</span>
                </div>
                <div class="w-full bg-white/5 h-1.5 rounded-full overflow-hidden">
                  <div class="bg-blue-400 h-full rounded-full shadow-[0_0_10px_rgba(96,165,250,0.5)]" style="width:99.9%"></div>
                </div>
              </div>
            </div>
            <div class="mt-8 pt-5 border-t border-white/5">
              <h3 class="md:text-xl text-lg font-semibold tracking-tight font-geist text-white">2. Authentication</h3>
              <p class="text-sm text-slate-400 font-geist mt-2">Continuous, privacy-preserving access controls adapting to real-time contextual signals.</p>
            </div>
          </div>
        </div>

        <!-- Feature 3: Reputation -->
        <div class="rounded-3xl bg-slate-900/40 ring-1 ring-white/10 backdrop-blur-md p-6 flex flex-col h-full animate-on-scroll [animation:fadeSlideIn_1s_ease-out_0.4s_both]">
          <div class="inline-flex items-center gap-2 rounded-full bg-white/5 px-3 py-1.5 text-xs font-medium text-white/80 ring-1 ring-white/10 font-geist w-fit mb-6">
            <iconify-icon icon="solar:graph-up-linear" class="text-sm text-purple-400"></iconify-icon>
            Network Consensus
          </div>
          <div class="flex-1 flex flex-col items-center justify-center py-6">
            <div class="relative w-32 h-32">
              <div class="absolute inset-0 rounded-full" style="background: conic-gradient(rgba(192,132,252,0.9) 0% 92%, rgba(255,255,255,0.05) 92% 100%);"></div>
              <div class="absolute inset-[3px] rounded-full bg-slate-950"></div>
              <div class="absolute inset-0 flex items-center justify-center flex-col">
                <div class="text-4xl font-medium tracking-tighter font-geist text-white">924</div>
                <span class="text-[10px] text-slate-400 font-geist tracking-widest uppercase mt-1">Trust Score</span>
              </div>
            </div>
          </div>
          <div class="mt-4 pt-5 border-t border-white/5 w-full">
            <h3 class="md:text-xl text-lg font-semibold tracking-tight font-geist text-white">3. Reputation</h3>
