---
import InnerLayout from '../../components/InnerLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('frameworks')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categoryColors: Record<string, string> = {
  'Identity Protocol': 'text-blue-400',
  'Security Architecture': 'text-emerald-400',
  'Cryptography': 'text-purple-400',
  'Agent Security': 'text-orange-400',
  'Network Dynamics': 'text-purple-400',
};
---

<InnerLayout
  title="Trust Frameworks & Protocols | TRST.com"
  description="In-depth articles on digital trust protocols, standards, and architectures: DID, OIDC, Zero-Knowledge Proofs, Zero Trust, and AI agent authentication."
>

  <section class="relative overflow-hidden py-24 bg-slate-950">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute inset-y-0 left-[12.5%] w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
      <div class="absolute inset-y-0 left-1/2 w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
      <div class="absolute inset-y-0 left-[87.5%] w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-8">
      <div class="inline-flex text-[11px] ring-1 ring-white/10 font-medium text-white/70 font-geist bg-white/5 rounded-full py-1.5 px-3 gap-2 items-center mb-4">
        Technical Deep-Dives
      </div>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-semibold tracking-tight font-geist text-white mb-6">
        Trust Frameworks
      </h1>
      <p class="text-lg text-white/70 leading-relaxed font-geist max-w-2xl">
        Explore the underlying architecture and specifications powering the 2026 digital trust economy.
      </p>
    </div>
  </section>

  <section class="relative bg-slate-950 py-16 border-t border-white/5">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute inset-y-0 left-[12.5%] w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
      <div class="absolute inset-y-0 left-1/2 w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
      <div class="absolute inset-y-0 left-[87.5%] w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {posts.map((post) => (
          <a
            href={`/frameworks/${post.id}`}
            class="group flex flex-col rounded-3xl bg-white/5 ring-1 ring-white/10 hover:ring-white/30 hover:bg-white/10 transition-all duration-300 overflow-hidden backdrop-blur-md animate-on-scroll [animation:fadeSlideIn_1s_ease-out_0.1s_both]"
          >
            <div class="p-6 flex-1 flex flex-col">
              <div class={`text-[11px] font-medium font-geist uppercase tracking-wider mb-3 ${categoryColors[post.data.category] || 'text-white/60'}`}>
                {post.data.category}
              </div>
              <h2 class="text-xl font-semibold tracking-tight text-white font-geist group-hover:text-blue-200 transition-colors mb-3">
                {post.data.title}
              </h2>
              <p class="text-sm text-slate-400 font-geist leading-relaxed flex-1">{post.data.description}</p>
              <div class="mt-6 pt-4 border-t border-white/5 flex items-center justify-between">
                <span class="text-xs text-slate-500 font-geist">{post.data.readTime}</span>
                <div class="flex items-center text-sm font-medium text-white/90 font-geist gap-2">
                  Read <iconify-icon icon="solar:arrow-right-linear" class="group-hover:translate-x-1 transition-transform"></iconify-icon>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="relative bg-slate-950 py-20 border-t border-white/5">
    <div class="max-w-2xl mx-auto px-6 md:px-8 text-center">
      <div class="inline-flex items-center gap-2 rounded-full bg-white/5 px-3 py-1.5 text-xs font-medium text-white/80 ring-1 ring-white/10 font-geist mb-4">
        <iconify-icon icon="solar:letter-linear" class="text-sm text-blue-400"></iconify-icon>
        The Trust Signal
      </div>
      <h2 class="text-2xl md:text-3xl font-semibold tracking-tight font-geist text-white mb-4">Weekly trust intelligence</h2>
      <p class="text-slate-400 font-geist mb-8">New frameworks, protocol updates, and infrastructure analysis in your inbox every week.</p>
      <a href="/newsletter" class="inline-flex items-center gap-2 ring-1 ring-white/20 transition hover:bg-neutral-100 text-sm font-medium text-neutral-900 font-geist bg-white rounded-full py-2.5 px-5">
        Subscribe to The Trust Signal
        <iconify-icon icon="solar:arrow-right-linear" class="text-base"></iconify-icon>
      </a>
    </div>
  </section>

</InnerLayout>
