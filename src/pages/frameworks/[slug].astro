---
import InnerLayout from '../../components/InnerLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('frameworks');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = (await getCollection('frameworks')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const related = allPosts.filter(p => p.id !== post.id).slice(0, 3);
---

<InnerLayout
  title={`${post.data.title} | TRST.com`}
  description={post.data.description}
>
  <!-- Breadcrumb -->
  <nav class="border-b border-white/5 bg-slate-950 py-3">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <ol class="flex items-center gap-2 text-xs text-slate-500 flex-wrap font-geist">
        <li><a href="/" class="hover:text-white transition">Home</a></li>
        <li class="text-slate-700">→</li>
        <li><a href="/frameworks" class="hover:text-white transition">Frameworks</a></li>
        <li class="text-slate-700">→</li>
        <li class="text-slate-300 truncate max-w-48">{post.data.title}</li>
      </ol>
    </div>
  </nav>

  <div class="bg-slate-950 max-w-7xl mx-auto px-6 md:px-8 py-12">
    <div class="grid lg:grid-cols-4 gap-12">
      <!-- Article -->
      <article class="lg:col-span-3">
        <header class="mb-10">
          <div class="flex items-center gap-3 mb-4">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-white/5 px-3 py-1 text-xs font-medium text-white/80 ring-1 ring-white/10 font-geist">
              {post.data.category}
            </span>
            <span class="text-xs text-slate-500 font-geist">{post.data.readTime}</span>
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight font-geist text-white mb-6 leading-tight">
            {post.data.title}
          </h1>
          <p class="text-lg text-white/70 leading-relaxed font-geist mb-6">{post.data.description}</p>
          <div class="flex items-center gap-4 text-sm text-slate-500 border-t border-white/5 pt-4 font-geist">
            <span>{post.data.author}</span>
            <span>·</span>
            <time datetime={post.data.date}>
              {new Date(post.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            </time>
          </div>
        </header>

        <div class="prose-content">
          <Content />
        </div>

        <div class="mt-12 pt-8 border-t border-white/5">
          <div class="rounded-2xl bg-slate-900/50 ring-1 ring-white/10 backdrop-blur-md p-6">
            <h3 class="font-semibold text-white font-geist mb-2">Assess Your Trust Maturity</h3>
            <p class="text-sm text-slate-400 font-geist mb-4">Take the Digital Trust Scorecard to see where your organization stands.</p>
            <a href="/scorecard" class="inline-flex items-center gap-2 ring-1 ring-white/20 text-sm font-medium text-neutral-900 font-geist bg-white rounded-full py-2 px-4">
              Take the Scorecard
              <iconify-icon icon="solar:arrow-right-linear" class="text-base"></iconify-icon>
            </a>
          </div>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <div class="rounded-2xl bg-slate-900/50 ring-1 ring-white/10 backdrop-blur-md p-5">
          <h3 class="font-semibold text-white font-geist mb-4 text-sm">More Articles</h3>
          <div class="space-y-4">
            {related.map(rel => (
              <a href={`/frameworks/${rel.id}`} class="block group">
                <div class="text-xs text-white/50 font-geist mb-1">{rel.data.category}</div>
                <div class="text-sm text-white/80 group-hover:text-white transition-colors leading-snug font-geist">
                  {rel.data.title}
                </div>
                <div class="text-xs text-slate-500 font-geist mt-1">{rel.data.readTime}</div>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-2xl bg-slate-900/50 ring-1 ring-white/10 backdrop-blur-md p-5">
          <h3 class="font-semibold text-white font-geist mb-3 text-sm">Trust Map</h3>
          <p class="text-xs text-slate-400 font-geist mb-4">Explore the providers implementing these standards.</p>
          <a href="/infrastructure" class="flex items-center gap-1.5 text-xs text-white/70 hover:text-white transition font-geist">
            View Infrastructure Map <iconify-icon icon="solar:arrow-right-linear"></iconify-icon>
          </a>
        </div>
      </aside>
    </div>

    {related.length > 0 && (
      <section class="mt-16 pt-8 border-t border-white/5">
        <h2 class="text-xl font-semibold text-white font-geist mb-6">Related Articles</h2>
        <div class="grid sm:grid-cols-3 gap-4">
          {related.map(rel => (
            <a href={`/frameworks/${rel.id}`} class="group rounded-2xl bg-slate-900/50 ring-1 ring-white/10 hover:ring-white/20 hover:bg-white/5 backdrop-blur-md transition-all p-5">
              <div class="text-xs text-white/50 font-geist mb-2">{rel.data.category}</div>
              <h3 class="font-semibold text-white group-hover:text-blue-200 transition-colors font-geist text-sm mb-2">
                {rel.data.title}
              </h3>
              <p class="text-xs text-slate-400 font-geist line-clamp-2">{rel.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</InnerLayout>

<style>
  .prose-content :global(h2) {
    font-family: 'Geist', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: #f1f5f9;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    padding-bottom: 0.5rem;
  }
  .prose-content :global(h3) {
    font-family: 'Geist', sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: #f1f5f9;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
  }
  .prose-content :global(p) {
    font-family: 'Geist', sans-serif;
    color: rgba(148, 163, 184, 1);
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .prose-content :global(ul), .prose-content :global(ol) {
    font-family: 'Geist', sans-serif;
    color: rgba(148, 163, 184, 1);
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .prose-content :global(li) {
    margin-bottom: 0.4rem;
    line-height: 1.7;
  }
  .prose-content :global(code) {
    font-size: 0.875em;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: #93c5fd;
  }
  .prose-content :global(pre) {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 0.75rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .prose-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: #93c5fd;
    font-size: 0.85rem;
  }
  .prose-content :global(blockquote) {
    border-left: 2px solid rgba(255,255,255,0.2);
    padding-left: 1rem;
    color: rgba(148, 163, 184, 0.8);
    font-style: italic;
    margin: 1.5rem 0;
  }
  .prose-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
  }
  .prose-content :global(th) {
    background: rgba(255,255,255,0.05);
    color: #f1f5f9;
    font-family: 'Geist', sans-serif;
    font-weight: 600;
    padding: 0.75rem 1rem;
    text-align: left;
    border: 1px solid rgba(255,255,255,0.08);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .prose-content :global(td) {
    padding: 0.75rem 1rem;
    border: 1px solid rgba(255,255,255,0.06);
    color: rgba(148, 163, 184, 1);
    font-family: 'Geist', sans-serif;
  }
  .prose-content :global(a) {
    color: #93c5fd;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-content :global(strong) {
    color: #f1f5f9;
    font-weight: 600;
  }
  .prose-content :global(hr) {
    border-color: rgba(255,255,255,0.08);
    margin: 2rem 0;
  }
</style>
