---
import InnerLayout from '../../components/InnerLayout.astro';
import { categories, providers, getProvidersByCategory } from '../../data/providers';
---

<InnerLayout
  title="Trust Infrastructure Map | TRST.com"
  description="The definitive directory of digital trust infrastructure—explore biometric authentication, decentralized identity, fraud prevention, zero trust security, and AI verification providers."
>
  <!-- Page Hero -->
  <section class="relative overflow-hidden py-24 bg-slate-950">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute inset-y-0 left-[12.5%] w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
      <div class="absolute inset-y-0 left-1/2 w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
      <div class="absolute inset-y-0 left-[87.5%] w-px bg-gradient-to-b from-transparent via-white/5 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-8">
      <div class="inline-flex items-center gap-2 rounded-full bg-white/5 px-3 py-1.5 text-xs font-medium text-white/80 ring-1 ring-white/10 font-geist mb-4">
        <iconify-icon icon="solar:layers-linear" class="text-sm text-blue-400"></iconify-icon>
        The Trust Stack
      </div>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-semibold tracking-tight font-geist text-white mb-6">Infrastructure Map</h1>
      <p class="text-lg text-white/70 leading-relaxed font-geist max-w-2xl">
        A hierarchical map of the technologies, protocols, and companies building the infrastructure of digital confidence.
        {providers.length} providers across {categories.length} categories.
      </p>
    </div>
  </section>

  <!-- Categories + Providers -->
  <div class="bg-slate-950 max-w-7xl mx-auto px-6 md:px-8 py-16 space-y-20">
    {categories.map(cat => {
      const catProviders = getProvidersByCategory(cat.slug);
      return (
        <section class="animate-on-scroll [animation:fadeSlideIn_1s_ease-out_0.1s_both]">
          <div class="flex items-start justify-between mb-8 pb-4 border-b border-white/5">
            <div>
              <h2 class="text-2xl font-semibold tracking-tight font-geist text-white mb-1">{cat.name}</h2>
              <p class="text-sm text-slate-400 font-geist max-w-xl">{cat.description}</p>
            </div>
            <a href={`/infrastructure/${cat.slug}`} class="hidden sm:flex items-center gap-1.5 text-sm text-white/60 hover:text-white transition font-geist shrink-0">
              View all {catProviders.length} <iconify-icon icon="solar:arrow-right-linear"></iconify-icon>
            </a>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {catProviders.map(provider => (
              <a
                href={`/infrastructure/${provider.categorySlug}/${provider.slug}`}
                class="group rounded-2xl bg-slate-900/50 ring-1 ring-white/10 hover:ring-white/20 hover:bg-white/5 backdrop-blur-md transition-all p-5"
              >
                <div class="flex items-start justify-between mb-3">
                  <h3 class="font-semibold text-white group-hover:text-blue-200 transition-colors font-geist">{provider.name}</h3>
                  <span class="text-xs font-medium text-white/50 font-geist ml-2 shrink-0 bg-white/5 px-2 py-0.5 rounded-full ring-1 ring-white/10">
                    {provider.trustScore}
                  </span>
                </div>
                <p class="text-xs text-slate-400 leading-relaxed font-geist mb-4 line-clamp-2">{provider.description}</p>
                <div class="w-full bg-white/5 h-1 rounded-full overflow-hidden mb-3">
                  <div class="bg-blue-400 h-full rounded-full" style={`width: ${provider.trustScore}%`}></div>
                </div>
                <div class="flex flex-wrap gap-1">
                  {provider.tags.slice(0, 2).map(tag => (
                    <span class="px-2 py-0.5 text-[10px] bg-white/5 ring-1 ring-white/10 text-slate-400 font-geist rounded-full">{tag}</span>
                  ))}
                </div>
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </div>

  <!-- CTA -->
  <section class="relative bg-slate-950 py-20 border-t border-white/5">
    <div class="max-w-4xl mx-auto px-6 md:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-semibold tracking-tight font-geist text-white mb-4">Is your infrastructure ready?</h2>
      <p class="text-slate-400 font-geist mb-8">Take the Digital Trust Scorecard to assess your organization's trust maturity.</p>
      <a href="/scorecard" class="inline-flex items-center gap-2 ring-1 ring-white/20 transition hover:bg-neutral-100 text-sm font-medium text-neutral-900 font-geist bg-white rounded-full py-2.5 px-5">
        Take the Scorecard
        <iconify-icon icon="solar:arrow-right-linear" class="text-base"></iconify-icon>
      </a>
    </div>
  </section>
</InnerLayout>
