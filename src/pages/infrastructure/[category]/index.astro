---
import InnerLayout from '../../../components/InnerLayout.astro';
import { categories, providers, getProvidersByCategory, getCategory } from '../../../data/providers';

export function getStaticPaths() {
  return categories.map(cat => ({
    params: { category: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const catProviders = getProvidersByCategory(category.slug);
---

<InnerLayout
  title={`${category.name} Providers | Trust Infrastructure Map | TRST.com`}
  description={`Compare the top ${category.name.toLowerCase()} providers. ${category.description}`}
>
  <nav class="border-b border-white/5 bg-slate-950 py-3">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <ol class="flex items-center gap-2 text-xs text-slate-500 font-geist flex-wrap">
        <li><a href="/" class="hover:text-white transition">Home</a></li>
        <li>→</li>
        <li><a href="/infrastructure" class="hover:text-white transition">Trust Map</a></li>
        <li>→</li>
        <li class="text-slate-300">{category.name}</li>
      </ol>
    </div>
  </nav>

  <section class="relative overflow-hidden py-20 bg-slate-950">
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-8">
      <div class="inline-flex items-center gap-2 rounded-full bg-white/5 px-3 py-1.5 text-xs font-medium text-white/80 ring-1 ring-white/10 font-geist mb-4">
        <iconify-icon icon="solar:tag-linear" class="text-sm text-blue-400"></iconify-icon>
        Trust Category
      </div>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight font-geist text-white mb-4">{category.name}</h1>
      <p class="text-lg text-white/70 leading-relaxed font-geist max-w-2xl mb-2">{category.description}</p>
      <p class="text-xs text-slate-500 font-geist">{catProviders.length} providers indexed</p>
    </div>
  </section>

  <div class="bg-slate-950 max-w-7xl mx-auto px-6 md:px-8 py-12 border-t border-white/5">
    <div class="grid gap-4">
      {catProviders.map((provider, i) => (
        <a
          href={`/infrastructure/${provider.categorySlug}/${provider.slug}`}
          class="group rounded-2xl bg-slate-900/50 ring-1 ring-white/10 hover:ring-white/20 hover:bg-white/5 backdrop-blur-md transition-all p-6"
        >
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-xs text-slate-500 font-geist w-6">{String(i + 1).padStart(2, '0')}</span>
                <h2 class="text-xl font-semibold tracking-tight font-geist text-white group-hover:text-blue-200 transition-colors">{provider.name}</h2>
              </div>
              <p class="text-sm text-slate-400 leading-relaxed font-geist mb-4 ml-9">{provider.description}</p>
              <div class="ml-9 flex flex-wrap gap-2">
                {provider.tags.map(tag => (
                  <span class="px-2 py-0.5 text-[10px] bg-white/5 ring-1 ring-white/10 text-slate-400 font-geist rounded-full">{tag}</span>
                ))}
              </div>
            </div>
            <div class="shrink-0 text-right">
              <div class="text-3xl font-medium tracking-tighter font-geist text-white">{provider.trustScore}</div>
              <div class="text-xs text-slate-500 font-geist mt-1">Trust Score</div>
              <div class="mt-2 w-24 bg-white/5 h-1 rounded-full overflow-hidden ml-auto">
                <div class="bg-blue-400 h-full rounded-full" style={`width: ${provider.trustScore}%`}></div>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
    <div class="mt-8">
      <a href="/infrastructure" class="flex items-center gap-1.5 text-sm text-slate-400 hover:text-white transition font-geist">
        <iconify-icon icon="solar:arrow-left-linear"></iconify-icon> Back to Trust Map
      </a>
    </div>
  </div>
</InnerLayout>
