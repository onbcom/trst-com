---
import BaseLayout from '../../../components/BaseLayout.astro';
import { categories, providers, getProvidersByCategory, getCategory } from '../../../data/providers';

export function getStaticPaths() {
  return categories.map(cat => ({
    params: { category: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const catProviders = getProvidersByCategory(category.slug);
---

<BaseLayout
  title={`${category.name} Providers | Trust Infrastructure Map | TRST.com`}
  description={`Compare the top ${category.name.toLowerCase()} providers. ${category.description}`}
>
  <!-- Breadcrumb -->
  <nav class="border-b border-border py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ol class="flex items-center gap-2 text-xs text-muted">
        <li><a href="/" class="hover:text-ghost">Home</a></li>
        <li class="text-border">→</li>
        <li><a href="/infrastructure" class="hover:text-ghost">Trust Map</a></li>
        <li class="text-border">→</li>
        <li class="text-ghost">{category.name}</li>
      </ol>
    </div>
  </nav>

  <!-- Header -->
  <section class="border-b border-border py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-4 mb-4">
        <span class="text-5xl">{category.icon}</span>
        <div>
          <p class="font-mono text-xs text-mint uppercase tracking-widest mb-1">Trust Category</p>
          <h1 class="text-4xl font-extrabold">{category.name}</h1>
        </div>
      </div>
      <p class="text-ghost/70 max-w-2xl text-lg mt-4">{category.description}</p>
      <p class="font-mono text-xs text-muted mt-3">{catProviders.length} providers indexed</p>
    </div>
  </section>

  <!-- Providers -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid gap-6">
      {catProviders.map((provider, i) => (
        <a
          href={`/infrastructure/${provider.categorySlug}/${provider.slug}`}
          class="card p-6 hover:border-mint/40 hover:bg-mint/5 transition-all group"
        >
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <span class="font-mono text-xs text-muted w-4">{String(i + 1).padStart(2, '0')}</span>
                <h2 class="text-xl font-bold text-ghost group-hover:text-mint transition-colors">{provider.name}</h2>
              </div>
              <p class="text-sm text-muted leading-relaxed mb-4 ml-7">{provider.description}</p>
              <div class="ml-7 flex flex-wrap gap-2">
                {provider.tags.map(tag => (
                  <span class="px-2 py-0.5 text-xs bg-border/50 text-muted rounded">{tag}</span>
                ))}
              </div>
            </div>
            <div class="shrink-0 text-right">
              <div class="font-mono text-3xl font-bold text-mint">{provider.trustScore}</div>
              <div class="text-xs text-muted mt-1">Trust Score</div>
              <div class="mt-3 w-24 score-bar ml-auto">
                <div class="score-bar-fill" style={`width: ${provider.trustScore}%`}></div>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- Back -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <a href="/infrastructure" class="text-sm text-muted hover:text-mint transition-colors">← Back to Trust Map</a>
  </div>
</BaseLayout>
