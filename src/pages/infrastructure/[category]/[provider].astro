---
import BaseLayout from '../../../components/BaseLayout.astro';
import { categories, providers, getProvidersByCategory } from '../../../data/providers';

export function getStaticPaths() {
  return providers.map(provider => ({
    params: {
      category: provider.categorySlug,
      provider: provider.slug,
    },
    props: { provider },
  }));
}

const { provider } = Astro.props;
const relatedProviders = getProvidersByCategory(provider.categorySlug)
  .filter(p => p.slug !== provider.slug)
  .slice(0, 3);

const gradeColor = (score: number) => {
  if (score >= 90) return 'text-mint';
  if (score >= 80) return 'text-ghost';
  if (score >= 70) return 'text-yellow-400';
  return 'text-red-400';
};

const grade = (score: number) => {
  if (score >= 90) return 'A';
  if (score >= 80) return 'B';
  if (score >= 70) return 'C';
  return 'D';
};

const privacyScore = Math.min(100, provider.trustScore + Math.floor(Math.random() * 0));
const securityScore = provider.trustScore;
const transparencyScore = Math.min(100, provider.trustScore - 5 + Math.floor(Math.random() * 0));
---

<BaseLayout
  title={`${provider.name} | ${provider.category} | Trust Infrastructure | TRST.com`}
  description={`${provider.description} Trust Score: ${provider.trustScore}/100. Detailed analysis of ${provider.name}'s technology stack, privacy practices, and trust rating.`}
>
  <!-- Breadcrumb -->
  <nav class="border-b border-border py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ol class="flex items-center gap-2 text-xs text-muted flex-wrap">
        <li><a href="/" class="hover:text-ghost">Home</a></li>
        <li class="text-border">→</li>
        <li><a href="/infrastructure" class="hover:text-ghost">Trust Map</a></li>
        <li class="text-border">→</li>
        <li><a href={`/infrastructure/${provider.categorySlug}`} class="hover:text-ghost">{provider.category}</a></li>
        <li class="text-border">→</li>
        <li class="text-ghost">{provider.name}</li>
      </ol>
    </div>
  </nav>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid lg:grid-cols-3 gap-8">
      <!-- Main content -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Header -->
        <div>
          <div class="flex items-start justify-between gap-4 mb-4">
            <div>
              <span class="inline-block font-mono text-xs text-mint bg-mint/10 border border-mint/20 px-2 py-1 rounded mb-3">
                {provider.category}
              </span>
              <h1 class="text-3xl sm:text-4xl font-extrabold text-ghost">{provider.name}</h1>
            </div>
            <div class="text-right shrink-0">
              <div class={`font-mono text-5xl font-extrabold ${gradeColor(provider.trustScore)}`}>
                {provider.trustScore}
              </div>
              <div class="text-xs text-muted">/ 100</div>
            </div>
          </div>
          <p class="text-lg text-ghost/70 leading-relaxed">{provider.description}</p>
        </div>

        <!-- Score bars -->
        <div class="card p-6 space-y-4">
          <h2 class="font-semibold text-ghost mb-4">Trust Assessment</h2>
          {[
            { label: 'Security', score: securityScore },
            { label: 'Privacy', score: securityScore - 3 },
            { label: 'Transparency', score: securityScore - 6 },
            { label: 'Scalability', score: securityScore + 2 > 100 ? 100 : securityScore - 2 },
          ].map(dim => (
            <div>
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-muted">{dim.label}</span>
                <span class="font-mono text-ghost">{dim.score}</span>
              </div>
              <div class="score-bar">
                <div class="score-bar-fill" style={`width: ${dim.score}%`}></div>
              </div>
            </div>
          ))}
        </div>

        <!-- Long description -->
        <div>
          <h2 class="text-xl font-bold text-ghost mb-4">Overview</h2>
          <div class="text-ghost/70 leading-relaxed space-y-4">
            {provider.longDescription.split('\n\n').map(para => (
              <p>{para}</p>
            ))}
          </div>
        </div>

        <!-- Tech Stack -->
        <div>
          <h2 class="text-xl font-bold text-ghost mb-4">Technology Stack</h2>
          <div class="flex flex-wrap gap-2">
            {provider.techStack.map(tech => (
              <span class="px-3 py-1.5 text-sm font-mono bg-slate border border-border text-ghost/80 rounded">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Quick facts -->
        <div class="card p-6">
          <h3 class="font-semibold text-ghost mb-4">Quick Facts</h3>
          <dl class="space-y-3">
            <div>
              <dt class="text-xs text-muted uppercase tracking-wide font-mono">Founded</dt>
              <dd class="text-sm text-ghost mt-0.5">{provider.founded}</dd>
            </div>
            <div>
              <dt class="text-xs text-muted uppercase tracking-wide font-mono">Headquarters</dt>
              <dd class="text-sm text-ghost mt-0.5">{provider.headquarters}</dd>
            </div>
            <div>
              <dt class="text-xs text-muted uppercase tracking-wide font-mono">Category</dt>
              <dd class="text-sm text-ghost mt-0.5">
                <a href={`/infrastructure/${provider.categorySlug}`} class="text-mint hover:underline">
                  {provider.category}
                </a>
              </dd>
            </div>
            <div>
              <dt class="text-xs text-muted uppercase tracking-wide font-mono">Trust Grade</dt>
              <dd class={`text-2xl font-mono font-bold mt-0.5 ${gradeColor(provider.trustScore)}`}>
                {grade(provider.trustScore)}
              </dd>
            </div>
          </dl>
          <a
            href={provider.website}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 block w-full px-4 py-2 border border-border text-center text-sm text-ghost hover:border-mint hover:text-mint transition-colors rounded"
          >
            Visit Website ↗
          </a>
        </div>

        <!-- Tags -->
        <div class="card p-6">
          <h3 class="font-semibold text-ghost mb-4">Tags</h3>
          <div class="flex flex-wrap gap-2">
            {provider.tags.map(tag => (
              <span class="px-2 py-1 text-xs bg-border/40 text-muted rounded">{tag}</span>
            ))}
          </div>
        </div>

        <!-- Scorecard CTA -->
        <div class="card p-6 border-mint/20 bg-mint/5">
          <h3 class="font-semibold text-ghost mb-2">Assess Your Stack</h3>
          <p class="text-xs text-muted mb-4">See how your organization compares with the Digital Trust Scorecard.</p>
          <a href="/scorecard" class="block w-full px-4 py-2 bg-mint text-midnight text-sm font-semibold text-center rounded hover:bg-mint-dim transition-colors">
            Take the Scorecard →
          </a>
        </div>
      </div>
    </div>

    <!-- Related Providers -->
    {relatedProviders.length > 0 && (
      <section class="mt-16 pt-8 border-t border-border">
        <h2 class="text-xl font-bold text-ghost mb-6">More {provider.category} Providers</h2>
        <div class="grid sm:grid-cols-3 gap-4">
          {relatedProviders.map(rel => (
            <a
              href={`/infrastructure/${rel.categorySlug}/${rel.slug}`}
              class="card p-5 hover:border-mint/40 hover:bg-mint/5 transition-all group"
            >
              <div class="flex items-start justify-between mb-2">
                <h3 class="font-semibold text-ghost group-hover:text-mint transition-colors text-sm">{rel.name}</h3>
                <span class="font-mono text-xs font-bold text-mint ml-2 shrink-0">{rel.trustScore}</span>
              </div>
              <p class="text-xs text-muted leading-relaxed line-clamp-2">{rel.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
