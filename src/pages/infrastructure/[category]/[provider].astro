---
import InnerLayout from '../../../components/InnerLayout.astro';
import { categories, providers, getProvidersByCategory } from '../../../data/providers';

export function getStaticPaths() {
  return providers.map(provider => ({
    params: {
      category: provider.categorySlug,
      provider: provider.slug,
    },
    props: { provider },
  }));
}

const { provider } = Astro.props;
const relatedProviders = getProvidersByCategory(provider.categorySlug)
  .filter(p => p.slug !== provider.slug)
  .slice(0, 3);

const gradeColor = (score: number) => {
  if (score >= 90) return 'text-emerald-400';
  if (score >= 80) return 'text-blue-300';
  if (score >= 70) return 'text-yellow-400';
  return 'text-red-400';
};

const grade = (score: number) => {
  if (score >= 90) return 'A';
  if (score >= 80) return 'B';
  if (score >= 70) return 'C';
  return 'D';
};

const privacyScore = Math.min(100, provider.trustScore + Math.floor(Math.random() * 0));
const securityScore = provider.trustScore;
const transparencyScore = Math.min(100, provider.trustScore - 5 + Math.floor(Math.random() * 0));
---

<InnerLayout
  title={`${provider.name} | ${provider.category} | Trust Infrastructure | TRST.com`}
  description={`${provider.description} Trust Score: ${provider.trustScore}/100. Detailed analysis of ${provider.name}'s technology stack, privacy practices, and trust rating.`}
>
  <nav class="border-b border-white/5 bg-slate-950 py-3">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <ol class="flex items-center gap-2 text-xs text-slate-500 font-geist flex-wrap">
        <li><a href="/" class="hover:text-white transition">Home</a></li>
        <li>→</li>
        <li><a href="/infrastructure" class="hover:text-white transition">Trust Map</a></li>
        <li>→</li>
        <li><a href={`/infrastructure/${provider.categorySlug}`} class="hover:text-white transition">{provider.category}</a></li>
        <li>→</li>
        <li class="text-slate-300">{provider.name}</li>
      </ol>
    </div>
  </nav>

  <div class="bg-slate-950 max-w-7xl mx-auto px-6 md:px-8 py-12">
    <div class="grid lg:grid-cols-3 gap-8">
      <!-- Main content -->
      <div class="lg:col-span-2 space-y-8">
        <div>
          <div class="flex items-start justify-between gap-4 mb-4">
            <div>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-white/5 px-3 py-1 text-xs font-medium text-white/80 ring-1 ring-white/10 font-geist mb-3">
                {provider.category}
              </span>
              <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight font-geist text-white">{provider.name}</h1>
            </div>
            <div class="text-right shrink-0">
              <div class={`text-5xl font-medium tracking-tighter font-geist ${gradeColor(provider.trustScore)}`}>
                {provider.trustScore}
              </div>
              <div class="text-xs text-slate-500 font-geist">/ 100</div>
            </div>
          </div>
          <p class="text-lg text-white/70 leading-relaxed font-geist">{provider.description}</p>
        </div>

        <div class="rounded-2xl bg-slate-900/50 ring-1 ring-white/10 backdrop-blur-md p-6 space-y-5">
          <h2 class="font-semibold text-white font-geist">Trust Assessment</h2>
          {[
            { label: 'Security', score: securityScore },
            { label: 'Privacy', score: securityScore - 3 },
            { label: 'Transparency', score: securityScore - 6 },
            { label: 'Scalability', score: securityScore - 2 < 0 ? 0 : securityScore - 2 },
          ].map(dim => (
            <div>
              <div class="flex justify-between text-sm mb-2">
                <span class="text-slate-300 font-geist">{dim.label}</span>
                <span class="text-white font-geist font-medium">{dim.score}</span>
              </div>
              <div class="w-full bg-white/5 h-1.5 rounded-full overflow-hidden">
                <div class="bg-blue-400 h-full rounded-full shadow-[0_0_10px_rgba(96,165,250,0.4)]" style={`width: ${dim.score}%`}></div>
              </div>
            </div>
          ))}
        </div>

        <div>
          <h2 class="text-xl font-semibold tracking-tight font-geist text-white mb-4">Overview</h2>
          <div class="text-white/70 leading-relaxed font-geist space-y-4">
            {provider.longDescription.split('\n\n').map(para => (
              <p>{para}</p>
            ))}
          </div>
        </div>

        <div>
          <h2 class="text-xl font-semibold tracking-tight font-geist text-white mb-4">Technology Stack</h2>
          <div class="flex flex-wrap gap-2">
            {provider.techStack.map(tech => (
              <span class="px-3 py-1.5 text-sm font-geist bg-white/5 ring-1 ring-white/10 text-slate-300 rounded-full">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <div class="rounded-2xl bg-slate-900/50 ring-1 ring-white/10 backdrop-blur-md p-6">
          <h3 class="font-semibold text-white font-geist mb-4">Quick Facts</h3>
          <dl class="space-y-3">
            <div>
              <dt class="text-xs text-slate-500 uppercase tracking-wider font-geist">Founded</dt>
              <dd class="text-sm text-white font-geist mt-0.5">{provider.founded}</dd>
            </div>
            <div>
              <dt class="text-xs text-slate-500 uppercase tracking-wider font-geist">Headquarters</dt>
              <dd class="text-sm text-white font-geist mt-0.5">{provider.headquarters}</dd>
            </div>
            <div>
              <dt class="text-xs text-slate-500 uppercase tracking-wider font-geist">Category</dt>
              <dd class="text-sm mt-0.5">
                <a href={`/infrastructure/${provider.categorySlug}`} class="text-blue-300 hover:text-blue-200 transition font-geist">
                  {provider.category}
                </a>
              </dd>
            </div>
            <div>
              <dt class="text-xs text-slate-500 uppercase tracking-wider font-geist">Trust Grade</dt>
              <dd class={`text-2xl font-medium tracking-tighter font-geist mt-0.5 ${gradeColor(provider.trustScore)}`}>
                {grade(provider.trustScore)}
              </dd>
            </div>
          </dl>
          <a
            href={provider.website}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 flex items-center justify-center gap-2 w-full ring-1 ring-white/20 transition hover:bg-white/10 text-sm font-medium text-white/80 font-geist rounded-full py-2.5 px-4"
          >
            Visit Website
            <iconify-icon icon="solar:arrow-right-up-linear" class="text-base"></iconify-icon>
          </a>
        </div>

        <div class="rounded-2xl bg-slate-900/50 ring-1 ring-white/10 backdrop-blur-md p-6">
          <h3 class="font-semibold text-white font-geist mb-4">Tags</h3>
          <div class="flex flex-wrap gap-2">
            {provider.tags.map(tag => (
              <span class="px-2 py-0.5 text-xs bg-white/5 ring-1 ring-white/10 text-slate-400 font-geist rounded-full">{tag}</span>
            ))}
          </div>
        </div>

        <div class="rounded-2xl bg-slate-900/50 ring-1 ring-white/10 backdrop-blur-md p-6">
          <h3 class="font-semibold text-white font-geist mb-2">Assess Your Stack</h3>
          <p class="text-xs text-slate-400 font-geist mb-4">See how your organization compares with the Digital Trust Scorecard.</p>
          <a href="/scorecard" class="flex items-center justify-center gap-2 w-full ring-1 ring-white/20 transition hover:bg-neutral-100 text-sm font-medium text-neutral-900 font-geist bg-white rounded-full py-2.5 px-4">
            Take the Scorecard
            <iconify-icon icon="solar:arrow-right-linear" class="text-base"></iconify-icon>
          </a>
        </div>
      </div>
    </div>

    {relatedProviders.length > 0 && (
      <section class="mt-16 pt-8 border-t border-white/5">
        <h2 class="text-xl font-semibold tracking-tight font-geist text-white mb-6">More {provider.category} Providers</h2>
        <div class="grid sm:grid-cols-3 gap-4">
          {relatedProviders.map(rel => (
            <a
              href={`/infrastructure/${rel.categorySlug}/${rel.slug}`}
              class="group rounded-2xl bg-slate-900/50 ring-1 ring-white/10 hover:ring-white/20 hover:bg-white/5 backdrop-blur-md transition-all p-5"
            >
              <div class="flex items-start justify-between mb-2">
                <h3 class="font-semibold text-white group-hover:text-blue-200 transition-colors font-geist text-sm">{rel.name}</h3>
                <span class="text-xs font-medium text-white/50 font-geist ml-2 shrink-0">{rel.trustScore}</span>
              </div>
              <p class="text-xs text-slate-400 font-geist leading-relaxed line-clamp-2">{rel.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</InnerLayout>
