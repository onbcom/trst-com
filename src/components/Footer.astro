---

<footer class="overflow-hidden bg-slate-950 border-white/5 border-t relative">
  <div class="pointer-events-none z-0 absolute inset-0">
    <div class="absolute inset-y-0 left-[12.5%] w-px bg-gradient-to-b from-white/5 via-white/5 to-transparent"></div>
    <div class="absolute inset-y-0 left-[37.5%] w-px bg-gradient-to-b from-white/5 via-white/5 to-transparent"></div>
    <div class="absolute inset-y-0 left-1/2 w-px bg-gradient-to-b from-white/5 via-white/5 to-transparent"></div>
    <div class="absolute inset-y-0 left-[62.5%] w-px bg-gradient-to-b from-white/5 via-white/5 to-transparent"></div>
  </div>

  <div class="z-10 md:px-8 lg:py-20 max-w-7xl mx-auto py-16 px-6 relative">
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-8 lg:gap-12">
      <!-- Brand -->
      <div class="col-span-2">
        <span class="text-2xl font-semibold tracking-tight text-white font-geist">TRST.com</span>
        <p class="mt-4 text-sm text-slate-400 leading-relaxed font-geist max-w-xs">
          Architecting a Trustworthy Future. The definitive layer for identity, authentication, and reputation.
        </p>
        <div class="mt-6 flex items-center gap-3">
          <a href="#" class="w-9 h-9 rounded-full bg-white/5 ring-1 ring-white/10 flex items-center justify-center text-slate-400 hover:bg-white/10 hover:text-white transition">
            <iconify-icon icon="solar:map-arrow-up-linear" class="text-lg"></iconify-icon>
          </a>
          <a href="/newsletter" class="w-9 h-9 rounded-full bg-white/5 ring-1 ring-white/10 flex items-center justify-center text-slate-400 hover:bg-white/10 hover:text-white transition">
            <iconify-icon icon="solar:letter-opened-linear" class="text-lg"></iconify-icon>
          </a>
        </div>
      </div>

      <!-- Platform -->
      <div>
        <h3 class="text-sm font-medium text-white font-geist">Platform</h3>
        <ul class="mt-4 space-y-3">
          <li><a href="/infrastructure" class="text-sm text-slate-400 hover:text-white transition font-geist">Infrastructure Map</a></li>
          <li><a href="/frameworks" class="text-sm text-slate-400 hover:text-white transition font-geist">Frameworks</a></li>
          <li><a href="/scorecard" class="text-sm text-slate-400 hover:text-white transition font-geist">Scorecard API</a></li>
          <li><a href="#" class="text-sm text-slate-400 hover:text-white transition font-geist">Network Status</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-sm font-medium text-white font-geist">Resources</h3>
        <ul class="mt-4 space-y-3">
          <li><a href="/frameworks" class="text-sm text-slate-400 hover:text-white transition font-geist">Documentation</a></li>
          <li><a href="/frameworks" class="text-sm text-slate-400 hover:text-white transition font-geist">Whitepapers</a></li>
          <li><a href="/frameworks" class="text-sm text-slate-400 hover:text-white transition font-geist">Developer Hub</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-medium text-white font-geist">Company</h3>
        <ul class="mt-4 space-y-3">
          <li><a href="/about" class="text-sm text-slate-400 hover:text-white transition font-geist">About Us</a></li>
          <li><a href="#" class="text-sm text-slate-400 hover:text-white transition font-geist">Careers</a></li>
          <li><a href="#" class="text-sm text-slate-400 hover:text-white transition font-geist">Contact</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-sm font-medium text-white font-geist">Legal</h3>
        <ul class="mt-4 space-y-3">
          <li><a href="#" class="text-sm text-slate-400 hover:text-white transition font-geist">Privacy Policy</a></li>
          <li><a href="#" class="text-sm text-slate-400 hover:text-white transition font-geist">Terms of Use</a></li>
          <li><a href="#" class="text-sm text-slate-400 hover:text-white transition font-geist">Compliance</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-8 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-slate-400 font-geist">© 2026 TRST.com. Architecting a Trustworthy Future.</p>
    </div>
  </div>
</footer>
