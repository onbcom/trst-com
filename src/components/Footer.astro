---
const year = new Date().getFullYear();

const links = {
  'Infrastructure': [
    { href: '/infrastructure', label: 'Trust Map' },
    { href: '/infrastructure/decentralized-identity', label: 'Decentralized Identity' },
    { href: '/infrastructure/biometric-authentication', label: 'Biometric Auth' },
    { href: '/infrastructure/fraud-prevention', label: 'Fraud Prevention' },
  ],
  'Frameworks': [
    { href: '/frameworks', label: 'All Articles' },
    { href: '/frameworks/did-foundation', label: 'What is DID?' },
    { href: '/frameworks/zero-knowledge-proofs', label: 'Zero-Knowledge Proofs' },
    { href: '/frameworks/ai-agent-authentication', label: 'AI Agent Auth' },
  ],
  'Tools': [
    { href: '/scorecard', label: 'Trust Scorecard' },
    { href: '/newsletter', label: 'The Trust Signal' },
  ],
  'Company': [
    { href: '/about', label: 'About TRST' },
  ],
};
---

<footer class="border-t border-border mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <span class="font-mono text-xl font-bold text-mint">TRST</span>
          <span class="font-mono text-xs text-muted border border-border px-1 py-0.5 rounded">.com</span>
        </a>
        <p class="text-sm text-muted leading-relaxed">
          The definitive authority on digital trust infrastructure.
        </p>
      </div>

      <!-- Nav columns -->
      {Object.entries(links).map(([section, items]) => (
        <div>
          <h3 class="text-xs font-semibold text-mint uppercase tracking-widest mb-4">
            {section}
          </h3>
          <ul class="space-y-2">
            {items.map(item => (
              <li>
                <a href={item.href} class="text-sm text-muted hover:text-ghost transition-colors">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-border flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-muted">
        &copy; {year} TRST.com — Digital Trust Infrastructure Authority
      </p>
      <p class="text-xs text-muted">
        Provides technological analysis. Not a legal or security auditing firm.
      </p>
    </div>
  </div>
</footer>
