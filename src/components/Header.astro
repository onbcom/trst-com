---
const { pathname } = Astro.url;
---

<header class="inner-header sticky top-0 z-50 w-full">
  <div class="flex md:px-8 max-w-7xl mx-auto py-5 px-6 items-center justify-between">
    <!-- Left: brand + primary nav -->
    <div class="flex md:gap-6 ring-white/5 ring-1 rounded-full p-1 gap-4 items-center bg-black/20 backdrop-blur-md">
      <a href="/" class="inline-flex items-center justify-center px-4 h-[36px] rounded-full text-white font-geist font-semibold tracking-tight text-lg">TRST.com</a>
      <nav class="hidden md:flex gap-2 items-center">
        <a href="/infrastructure" class={`inline-flex items-center gap-2 transition hover:bg-white/10 hover:ring-white/20 text-sm font-medium font-geist ring-1 rounded-full py-2 px-3.5 backdrop-blur-sm ${pathname.startsWith('/infrastructure') ? 'text-white bg-white/10 ring-white/20' : 'text-white/90 bg-white/5 ring-white/10'}`}>
          Infrastructure Map
        </a>
        <a href="/frameworks" class={`inline-flex items-center gap-2 transition hover:bg-white/10 hover:ring-white/20 text-sm font-medium font-geist ring-1 rounded-full py-2 px-3.5 backdrop-blur-sm ${pathname.startsWith('/frameworks') ? 'text-white bg-white/10 ring-white/20' : 'text-white/90 bg-white/5 ring-white/10'}`}>
          Frameworks
        </a>
        <a href="/scorecard" class={`inline-flex items-center gap-2 transition hover:bg-white/10 hover:ring-white/20 text-sm font-medium font-geist ring-1 rounded-full py-2 px-3.5 backdrop-blur-sm ${pathname === '/scorecard' ? 'text-white bg-white/10 ring-white/20' : 'text-white/90 bg-white/5 ring-white/10'}`}>
          Scorecard
        </a>
        <a href="/about" class={`inline-flex items-center gap-2 transition hover:bg-white/10 hover:ring-white/20 text-sm font-medium font-geist ring-1 rounded-full py-2 px-3.5 backdrop-blur-sm ${pathname === '/about' ? 'text-white bg-white/10 ring-white/20' : 'text-white/90 bg-white/5 ring-white/10'}`}>
          About
        </a>
      </nav>
    </div>

    <!-- Right: CTA + mobile menu -->
    <div class="flex gap-2 items-center">
      <div class="hidden sm:flex ring-white/5 ring-1 rounded-full p-1 gap-2 items-center bg-black/20 backdrop-blur-md">
        <a href="/infrastructure" class="inline-flex items-center gap-2 transition hover:bg-white/10 hover:ring-white/20 text-sm font-medium text-white/90 font-geist bg-white/5 ring-white/10 ring-1 rounded-full py-2 px-3.5 backdrop-blur-sm">
          Explore the Trust Map
        </a>
      </div>
      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden w-9 h-9 rounded-full bg-white/5 ring-1 ring-white/10 flex items-center justify-center text-slate-400 hover:bg-white/10 hover:text-white transition" aria-label="Toggle menu">
        <iconify-icon icon="solar:hamburger-menu-linear" class="text-lg"></iconify-icon>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-black/30 backdrop-blur-md">
    <nav class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-2">
      <a href="/infrastructure" class="text-sm font-medium text-white/80 font-geist py-2 px-3 rounded-xl hover:bg-white/10 transition">Infrastructure Map</a>
      <a href="/frameworks" class="text-sm font-medium text-white/80 font-geist py-2 px-3 rounded-xl hover:bg-white/10 transition">Frameworks</a>
      <a href="/scorecard" class="text-sm font-medium text-white/80 font-geist py-2 px-3 rounded-xl hover:bg-white/10 transition">Scorecard</a>
      <a href="/about" class="text-sm font-medium text-white/80 font-geist py-2 px-3 rounded-xl hover:bg-white/10 transition">About</a>
      <a href="/infrastructure" class="mt-2 inline-flex items-center justify-center gap-2 ring-1 ring-white/20 text-sm font-medium text-neutral-900 font-geist bg-white rounded-full py-2.5 px-4">
        Explore the Trust Map
        <iconify-icon icon="solar:arrow-right-linear" class="text-base"></iconify-icon>
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
